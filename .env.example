# Copy this file to .env and fill in your values.
# Never commit .env to git.

# OpenRouter API key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: override default token budget (500_000 tokens)
# CARTOGRAPHER_TOKEN_BUDGET=500000

# Technical Thresholds (Defaults shown)
# CARTOGRAPHER_DIR=.cartography
# CARTOGRAPHER_CLONE_ROOT=.cartography_repos
# CARTOGRAPHER_MAX_SOURCE_BYTES=32000
# CARTOGRAPHER_KMEANS_K_MIN=5
# CARTOGRAPHER_KMEANS_K_MAX=8
# CARTOGRAPHER_STRONGLY_CONNECTED_MIN=2
# CARTOGRAPHER_DEFAULT_BUDGET_USD=10.0
